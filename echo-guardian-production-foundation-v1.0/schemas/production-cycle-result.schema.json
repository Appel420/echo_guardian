{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echo-guardian.local/schemas/production-cycle-result.schema.json",
  "title": "Echo Guardian Production Safety Cycle Result v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cycle_id",
    "created_at",
    "completed_at",
    "policy_authorized",
    "readiness_passed",
    "observation",
    "baseline_summary",
    "classification",
    "confirmation",
    "escalation",
    "local_status",
    "audit_verified",
    "audit_errors",
    "no_cloud_dependency",
    "no_private_space_monitoring",
    "hidden_behavior_present",
    "plain_language_summary",
    "audit_refs"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "0.2"},
    "cycle_id": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"},
    "policy_authorized": {"type": "boolean", "const": true},
    "readiness_passed": {"type": "boolean", "const": true},
    "observation": {"type": "object"},
    "baseline_summary": {"type": "object"},
    "classification": {"type": "object"},
    "confirmation": {"type": ["object", "null"]},
    "escalation": {"type": ["object", "null"]},
    "local_status": {"type": "object"},
    "audit_verified": {"type": "boolean"},
    "audit_errors": {"type": "array", "items": {"type": "string"}},
    "no_cloud_dependency": {"type": "boolean", "const": true},
    "no_private_space_monitoring": {"type": "boolean", "const": true},
    "hidden_behavior_present": {"type": "boolean", "const": false},
    "plain_language_summary": {"type": "string", "minLength": 1},
    "audit_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  }
}
